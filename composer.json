{
    "name": "marmot/laravel",
    "description": "Business-activity monitoring for Laravel: zero-config event capture, per-minute counts, flatline and anomaly alerts via Marmot.",
    "keywords": [
        "laravel",
        "monitoring",
        "business-activity",
        "anomaly-detection",
        "flatline",
        "alerting",
        "observability"
    ],
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Marmot\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marmot\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Marmot\\Laravel\\MarmotServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
